{
  "name": "kaizen-flow",
  "version": "0.1.0",
  "description": "Anti-akrasia mobile app - Transform procrastination into progress",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:mobile\"",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "migrate": "npm run migrate --workspace=packages/db",
    "seed": "npm run seed --workspace=packages/db",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Al1374525/kaizen-flow.git"
  },
  "author": "Albert Ayitey-Adjin <albertayiteyadjin@gmail.com>",
  "license": "MIT",
  "keywords": [
    "anti-akrasia",
    "procrastination",
    "behavioral-health",
    "mobile-app",
    "react-native",
    "gamification",
    "micro-commitments",
    "portfolio-project"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  }
}
