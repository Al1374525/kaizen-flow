# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/kaizen_flow
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/kaizen_flow_test

# Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# API Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Mobile App Configuration (Expo)
EXPO_PUBLIC_API_URL=http://localhost:3000

# AI Services (for Beta phase)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AI_DAILY_BUDGET_USD=10.00

# Push Notifications (for Week 7+)
EXPO_PUSH_TOKEN=your-expo-push-token

# Monitoring & Analytics
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
POSTHOG_API_KEY=phc_your-posthog-key

# Deployment
RAILWAY_TOKEN=your-railway-deployment-token
RENDER_API_KEY=your-render-api-key

# Development
DEBUG=kaizen:*
LOG_LEVEL=debug